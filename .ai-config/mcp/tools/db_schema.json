        {
          "name": "order_id",
          "type": "INTEGER",
          "foreignKey": {
            "reference": "orders.id",
            "onDelete": "CASCADE"
          }
        },
        {
          "name": "product_id",
          "type": "INTEGER",
          "foreignKey": {
            "reference": "products.id",
            "onDelete": "CASCADE"
          }
        },
        {
          "name": "quantity",
          "type": "INTEGER",
          "notNull": true
        },
        {
          "name": "price",
          "type": "DECIMAL(10, 2)",
          "notNull": true
        }
      ]
    }
