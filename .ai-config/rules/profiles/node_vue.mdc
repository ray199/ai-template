## 1. Vue 2（Options API）

### 1.1 工程结构

```
src/
  assets/
  components/        # 可复用组件（PascalCase）
  views/             # 页面级组件（路由对应）
  router/            # Vue Router 3
  store/             # Vuex store（index.js + modules/）
  api/               # 请求封装
  utils/
  mixins/            # Mixin 复用逻辑（谨慎使用，优先组件化）
  filters/           # 全局过滤器（Vue 3 已废弃）
```

### 1.2 Options API 规范

```vue
<template>
  <div class="user-form">
    <form @submit.prevent="handleSubmit">
      <input v-model="form.username" />
      <button type="submit" :disabled="isSubmitting">提交</button>
    </form>
  </div>
</template>

<script>
import { mapState, mapActions } from 'vuex';

export default {
  name: 'UserForm',

  // Props 必须带类型和默认值
  props: {
    userId: {
      type: Number,
      default: null
    },
    mode: {
      type: String,
      default: 'create',
      validator: (val) => ['create', 'edit'].includes(val)
    }
  },

  data() {
    return {
      form: { username: '', email: '' },
      isSubmitting: false,
      error: null
    };
  },

  computed: {
    ...mapState('user', ['currentUser']),
    isFormValid() {
      return this.form.username.length >= 3;
    }
  },

  watch: {
    userId(newId) {
      if (newId) this.loadUser(newId);
    }
  },

  created() {
    if (this.mode === 'edit' && this.userId) {
      this.loadUser(this.userId);
    }
  },

  beforeDestroy() {
    // 清理事件监听、定时器
  },

  methods: {
    ...mapActions('user', ['fetchUser', 'createUser']),
    async handleSubmit() {
      this.isSubmitting = true;
      try {
        await this.createUser(this.form);
        this.$emit('success');
      } catch (e) {
        this.error = e.message;
      } finally {
        this.isSubmitting = false;
      }
    },
    async loadUser(id) {
      const user = await this.fetchUser(id);
      this.form = { username: user.username, email: user.email };
    }
  }
};
</script>
```

### 1.3 Vue 2 专项约束（强制）

- **响应式新增属性**：禁止直接 `this.obj.newKey = val`，必须用 `this.$set(obj, key, val)` 或 `Vue.set`
- **数组变更**：禁止通过索引直接修改数组元素（`arr[0] = x`），必须用变异方法或 `$set`
- **禁止修改 Props**：禁止在组件内直接赋值给 props，必须通过 `$emit` 通知父组件
- **Mixin 限制**：Mixin 会导致来源不明，非必要不使用；业务复用优先用组件化
- **过滤器（filter）**：Vue 3 已废弃，新代码中禁止引入，旧代码维护时注意迁移计划
- **事件总线**：禁止新增 `new Vue()` 作为 EventBus，使用 Vuex 或组件通信替代

### 1.4 Vuex 规范

```javascript
// store/modules/user.js
export default {
  namespaced: true,
  state: () => ({           // state 必须是函数
    users: [],
    loading: false
  }),
  getters: {
    activeUsers: (state) => state.users.filter(u => u.active)
  },
  mutations: {              // 同步，命名 UPPER_SNAKE_CASE
    SET_USERS(state, users) { state.users = users; },
    SET_LOADING(state, val) { state.loading = val; }
  },
  actions: {                // 异步，camelCase
    async fetchUsers({ commit }) {
      commit('SET_LOADING', true);
      try {
        const users = await userApi.getList();
        commit('SET_USERS', users);
      } finally {
        commit('SET_LOADING', false);
      }
    }
  }
};
```

