## 2. Vue 3（Composition API）

### 2.1 工程结构

```
src/
  assets/
  components/        # 可复用组件（PascalCase）
  views/             # 页面级组件（路由对应）
  router/            # Vue Router 4
  stores/            # Pinia（复数）
  api/               # 请求封装
  utils/
  hooks/             # Composables（use 前缀）
  types/             # TypeScript 类型定义
```

### 2.2 Composition API 规范（`<script setup>`）

```vue
<script setup lang="ts">
import { ref, computed, watch, onMounted, onUnmounted } from 'vue';
import { useUserStore } from '@/stores/user';
import { useUser } from '@/hooks/useUser';

// Props — 必须带类型
const props = withDefaults(defineProps<{
  userId?: number;
  mode?: 'create' | 'edit';
}>(), { mode: 'create' });

// Emits — 必须声明
const emit = defineEmits<{
  success: [user: User];
  close: [];
}>();

const { createUser, getUserById } = useUser();
const userStore = useUserStore();

const form = ref({ username: '', email: '' });
const isSubmitting = ref(false);
const error = ref<string | null>(null);

const isFormValid = computed(() => form.value.username.length >= 3);

const handleSubmit = async () => {
  if (!isFormValid.value) return;
  isSubmitting.value = true;
  try {
    const user = await createUser(form.value);
    emit('success', user);
  } catch (e) {
    error.value = e instanceof Error ? e.message : '操作失败';
  } finally {
    isSubmitting.value = false;
  }
};

onMounted(() => {
  if (props.mode === 'edit' && props.userId) loadUser(props.userId);
});

// watch 必须在 onUnmounted 中清理，或使用 watchEffect 自动清理
const stopWatch = watch(() => props.userId, (id) => { if (id) loadUser(id); });
onUnmounted(() => stopWatch());
</script>
```

### 2.3 Vue 3 专项约束（强制）

- **`<script setup>` 优先**：新组件必须使用 `<script setup>`，禁止混用 Options API
- **禁止 `reactive` 滥用**：`reactive` 适用于复杂对象，一般用 `ref`；禁止对基本类型使用 `reactive`
- **Props 只读**：禁止修改 props，通过 `emit` 通知父组件
- **`v-html` 限制**：禁止将不可信内容赋给 `v-html`，必须经过安全净化
- **Composable 命名**：以 `use` 开头，返回响应式数据使用 `readonly` 包装防止外部直接修改

### 2.4 Pinia 规范

```typescript
// stores/user.ts
import { defineStore } from 'pinia';

export const useUserStore = defineStore('user', () => {
  // State
  const users = ref<User[]>([]);
  const loading = ref(false);

  // Getters（computed）
  const activeUsers = computed(() => users.value.filter(u => u.active));

  // Actions
  async function fetchUsers() {
    loading.value = true;
    try {
      users.value = await userApi.getList();
    } finally {
      loading.value = false;
    }
  }

  return { users: readonly(users), loading: readonly(loading), activeUsers, fetchUsers };
});
```

